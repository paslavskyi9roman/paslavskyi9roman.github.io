NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API key — when absent, the API returns the deterministic mock.
AI_API_KEY=
# Optional override; defaults to claude-haiku-4-5-20251001.
AI_MODEL=

# Upstash Redis credentials for rate limiting. When absent, rate limiting is disabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated origins permitted by `next dev` (e.g. http://192.168.1.10:3000,http://localhost:3000)
DEV_ALLOWED_ORIGINS=

# pino log level: trace|debug|info|warn|error|fatal (defaults to debug in dev, info in prod)
LOG_LEVEL=
